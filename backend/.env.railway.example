NODE_ENV=production
PORT=3000

# Referências aos serviços MongoDB e Redis criados no mesmo projeto Railway.
MONGO_URI=${{MongoDB.MONGO_URL}}
MONGO_DB=railway
REDIS_URL=${{Redis.REDIS_URL}}

# Referências ao Railway Bucket ligado ao backend.
BUCKET=${{Bucket.BUCKET}}
ENDPOINT=${{Bucket.ENDPOINT}}
REGION=${{Bucket.REGION}}
ACCESS_KEY_ID=${{Bucket.ACCESS_KEY_ID}}
SECRET_ACCESS_KEY=${{Bucket.SECRET_ACCESS_KEY}}

JWT_SECRET=gere-um-segredo-com-pelo-menos-32-caracteres
JWT_EXPIRES_IN=7d
CSRF_SECRET=gere-outro-segredo-com-pelo-menos-32-caracteres
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120
CORS_ORIGIN=https://seu-dominio.com

STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
BILLING_SUCCESS_URL=https://seu-dominio.com/app/billing
BILLING_CANCEL_URL=https://seu-dominio.com/app/billing

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_FROM_NAME=Nossa Família
PASSWORD_RESET_URL=https://seu-dominio.com/app/reset-password

FIREBASE_SERVICE_ACCOUNT_PATH=
