# Aplicação
NODE_ENV=production
PORT=3000
CORS_ORIGIN=https://seu-dominio.com

# Serviços do mesmo projeto Railway
# Ajuste MongoDB, Redis e Bucket se os serviços tiverem outros nomes.
MONGO_URI=${{MongoDB.MONGO_URL}}/my-family?authSource=admin
REDIS_URL=${{Redis.REDIS_URL}}

# Railway Bucket
BUCKET=${{Bucket.BUCKET}}
ENDPOINT=${{Bucket.ENDPOINT}}
REGION=${{Bucket.REGION}}
ACCESS_KEY_ID=${{Bucket.ACCESS_KEY_ID}}
SECRET_ACCESS_KEY=${{Bucket.SECRET_ACCESS_KEY}}

# Autenticação e segurança
JWT_SECRET=gere-um-segredo-com-pelo-menos-32-caracteres
JWT_EXPIRES_IN=7d
CSRF_SECRET=gere-outro-segredo-com-pelo-menos-32-caracteres
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
BILLING_SUCCESS_URL=https://seu-dominio.com/app/billing
BILLING_CANCEL_URL=https://seu-dominio.com/app/billing

# E-mail transacional
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@seu-dominio.com
EMAIL_FROM_NAME=Nossa Família
PASSWORD_RESET_URL=https://seu-dominio.com/app/reset-password

# Flutter Web (publico; usado no build do Dockerfile)
# Em Web, deixe as URLs vazias para usar o mesmo dominio atual.
API_BASE_URL=
SOCKET_URL=
PUBLIC_WEB_URL=
FIREBASE_API_KEY=
FIREBASE_APP_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_PROJECT_ID=
FIREBASE_AUTH_DOMAIN=
FIREBASE_STORAGE_BUCKET=
FIREBASE_WEB_PUSH_CERTIFICATE_KEY=

# Firebase Admin (opcional; JSON é mais adequado no Railway)
FIREBASE_SERVICE_ACCOUNT_JSON=
