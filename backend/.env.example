# Aplicação
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3458

# Banco de dados e filas
MONGO_URI=mongodb://localhost:27017/my-family
REDIS_URL=redis://localhost:6379

# Autenticação e segurança
JWT_SECRET=troque-por-um-segredo-com-pelo-menos-32-caracteres
JWT_EXPIRES_IN=7d
CSRF_SECRET=troque-por-outro-segredo-com-pelo-menos-32-caracteres
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120

# Bucket S3 compatível (obrigatório)
# Copie os cinco valores exibidos na aba Credentials do Railway Bucket.
BUCKET=
ENDPOINT=
REGION=
ACCESS_KEY_ID=
SECRET_ACCESS_KEY=

# Pagamentos
# O conjunto completo é opcional em desenvolvimento e obrigatório em produção.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
BILLING_SUCCESS_URL=http://localhost:3458/app/billing
BILLING_CANCEL_URL=http://localhost:3458/app/billing

# E-mail
# SMTP, remetente e URL de redefinição são obrigatórios em produção.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_FROM_NAME=Nossa Família
PASSWORD_RESET_URL=http://localhost:3458/app/reset-password

# Firebase Admin (opcional)
# Configure somente uma das duas opções.
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_SERVICE_ACCOUNT_JSON=
