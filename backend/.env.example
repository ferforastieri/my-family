NODE_ENV=development
PORT=3000
MONGO_URI=mongodb://localhost:27017/my-family
MONGO_DB=my-family
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=7d
UPLOAD_PATH=/caminho/absoluto/para/uploads
CORS_ORIGIN=*
