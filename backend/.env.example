SMTP_PASS=sua-senha-de-app
EMAIL_FROM=seu-email@gmail.com
EMAIL_FROM_NAME=Nossa Família
PASSWORD_RESET_URL=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Redis: local = redis://localhost:6379 | Docker (compose injeta) = redis://redis:6379
REDIS_URL=redis://localhost:6379
